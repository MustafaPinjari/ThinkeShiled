# ─── Database ────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_NAME=tendershield
DB_USER=tendershield
DB_PASSWORD=changeme_db
DB_HOST=db
DB_PORT=3306

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── JWT (RS256 key pair) ─────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content (with literal \n for newlines) below.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Access token lifetime in seconds (min 900 = 15 min, max 86400 = 24 hr)
JWT_ACCESS_TOKEN_LIFETIME=3600
# Refresh token lifetime in seconds (default 7 days)
JWT_REFRESH_TOKEN_LIFETIME=604800

# ─── Agency JWT Lifetimes ────────────────────────────────────────────────────
# Access token lifetime in minutes for agency users (default 15)
AGENCY_JWT_ACCESS_LIFETIME=15
# Refresh token lifetime in hours for agency users (default 24)
AGENCY_JWT_REFRESH_LIFETIME=24

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── SMTP (email notifications) ──────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=alerts@example.com
EMAIL_HOST_PASSWORD=changeme_smtp
DEFAULT_FROM_EMAIL=TenderShield Alerts <alerts@example.com>

# ─── ML Worker ───────────────────────────────────────────────────────────────
# Minimum hours between scheduled model retraining runs (default 24)
ML_RETRAIN_INTERVAL_HOURS=24
# Isolation Forest contamination parameter (0.0–0.5)
ML_IF_CONTAMINATION=0.05
# Path where serialized model artifacts are stored inside the container
ML_MODEL_PATH=/app/ml_worker/models

# ─── Alert Thresholds ────────────────────────────────────────────────────────
# Default fraud risk score threshold for triggering alerts (0–100)
ALERT_DEFAULT_THRESHOLD=70
